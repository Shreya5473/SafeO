<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_crm_lead_form_securec" model="ir.ui.view">
        <field name="name">crm.lead.form.securec</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[contains(@class,'oe_title')]" position="before">
                <field name="securec_flagged" invisible="1"/>
                <field name="securec_log_id" invisible="1"/>
                <div invisible="securec_risk_score == 0.0">
                    <div class="alert alert-warning mb-2" role="alert"
                         invisible="not securec_flagged">
                        <strong>SecureC Security Alert</strong>
                        — Risk: <field name="securec_risk_score" readonly="1" digits="[1,3]"/>
                        | Decision: <field name="securec_decision" readonly="1"/>
                        <div class="mt-1" style="font-size:13px;">
                            <field name="securec_explanation" readonly="1"/>
                        </div>
                    </div>
                    <div class="alert alert-success mb-2" role="alert"
                         invisible="securec_flagged">
                        <strong>SecureC:</strong>
                        Input cleared — Risk Score: <field name="securec_risk_score" readonly="1" digits="[1,3]"/>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
