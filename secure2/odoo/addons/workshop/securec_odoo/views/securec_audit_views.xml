<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_securec_audit_log_list" model="ir.ui.view">
        <field name="name">securec.audit.log.list</field>
        <field name="model">securec.audit.log</field>
        <field name="arch" type="xml">
            <list string="Security Activity Audit" default_order="timestamp desc"
                  decoration-danger="status == 'failed' or status == 'blocked'"
                  decoration-warning="status == 'warning'"
                  decoration-success="status == 'success'">
                <field name="timestamp"/>
                <field name="application"/>
                <field name="event_type" widget="badge"/>
                <field name="status" widget="badge"/>
                <field name="user_id"/>
                <field name="login"/>
                <field name="route"/>
                <field name="risk_score" optional="show"/>
                <field name="decision" optional="show"/>
                <field name="detected_language" optional="show"/>
                <field name="policy_region" optional="show"/>
                <field name="ip_address" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_securec_audit_log_form" model="ir.ui.view">
        <field name="name">securec.audit.log.form</field>
        <field name="model">securec.audit.log</field>
        <field name="arch" type="xml">
            <form string="Security Activity Event" create="false" edit="false">
                <sheet>
                    <group>
                        <group>
                            <field name="timestamp"/>
                            <field name="application"/>
                            <field name="event_type"/>
                            <field name="status"/>
                            <field name="user_id"/>
                            <field name="login"/>
                        </group>
                        <group>
                            <field name="route"/>
                            <field name="http_method"/>
                            <field name="ip_address"/>
                            <field name="user_agent"/>
                            <field name="policy_region"/>
                            <field name="detected_language"/>
                        </group>
                    </group>
                    <group string="Security Decision">
                        <field name="risk_score"/>
                        <field name="decision"/>
                        <field name="details" widget="text"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_securec_audit_log_search" model="ir.ui.view">
        <field name="name">securec.audit.log.search</field>
        <field name="model">securec.audit.log</field>
        <field name="arch" type="xml">
            <search string="Search Security Activity">
                <field name="application"/>
                <field name="event_type"/>
                <field name="status"/>
                <field name="user_id"/>
                <field name="login"/>
                <filter string="Login Success" name="login_success" domain="[('event_type','=','login_success')]"/>
                <filter string="Login Failed" name="login_failed" domain="[('event_type','=','login_failed')]"/>
                <filter string="Blocked" name="blocked" domain="[('status','=','blocked')]"/>
                <group>
                    <filter string="Application" name="by_application" context="{'group_by': 'application'}"/>
                    <filter string="Event Type" name="by_event_type" context="{'group_by': 'event_type'}"/>
                    <filter string="Status" name="by_status" context="{'group_by': 'status'}"/>
                    <filter string="User" name="by_user" context="{'group_by': 'user_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_securec_audit_log_list" model="ir.actions.act_window">
        <field name="name">Audit Activity</field>
        <field name="res_model">securec.audit.log</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_securec_audit_log_search"/>
    </record>
</odoo>
